# Go build/module cache inside repo
.go/
.cache/

# Build output. `go build ./...` writes each main package's binary into the
# working directory, so cmd/<name> becomes ./<name> at the repo root.
dist/
/swarmcli-cd

# Nothing named /controller belongs here: the entry point is the `controller`
# package at the repository root, and ignoring that path would silently drop it.

# Editors
.vscode/
.idea/

# Devcontainer metadata
.devcontainer/*.log
.devcontainer/devcontainer.local.json
.devcontainer/certs/*.pem
.devcontainer/certs/*.crt
.devcontainer/certs/corporate-proxy.crt
.devcontainer/shared/*

debug.log
